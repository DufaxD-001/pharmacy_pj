:{$PORT} {
    root * .
    encode gzip
    file_server

    # Routes all incoming web requests to your index.php file
    php_fastcgi 127.0.0.1:9000

    # Optional: If your project uses custom routing or pretty URLs, 
    # this ensures paths resolve correctly through index.php
    try_files {path} {path}/ /index.php?{query}
}
